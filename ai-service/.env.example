# Copy to .env in this folder. Configure at least one of: Azure OpenAI and/or OpenAI cloud.
# Restart uvicorn after changes.

# --- AssetRegister backend (Spring Boot) ---
ASSETREGISTER_ADMIN_CONSOLE_BASE_URL=http://127.0.0.1:9088/api/admin
ASSETREGISTER_DATA_BASE_URL=http://127.0.0.1:9088/api/data
# Optional service token if the AI service must call the backend without a user Bearer token
# ASSETREGISTER_SERVICE_TOKEN=

# CORS: comma-separated frontend origins allowed to call this AI service
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Optional: org id for cache warming (default default-org)
# ORG_ID=default-org

# SQLite state DB (default: ./data/ai_state.db under ai-service)
# AI_STATE_DB=./data/ai_state.db

# --- Azure OpenAI (deployment name = model id in the UI) ---
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
AZURE_OPENAI_DEPLOYMENT=gpt-4o-mini
AZURE_OPENAI_API_VERSION=2024-02-15-preview

# Optional: second Azure deployment (same pattern as primary)
# AZURE_OPENAI_2_API_KEY=
# AZURE_OPENAI_2_ENDPOINT=
# AZURE_OPENAI_2_DEPLOYMENT=
# AZURE_OPENAI_2_API_VERSION=2024-02-15-preview

# --- OpenAI cloud (same analyze / chat / global flows as Azure; Chat Completions API) ---
# https://platform.openai.com/api-keys
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
# Optional: second model (same key), shows as "OpenAI (2) – …" in the UI
# OPENAI_MODEL_2=gpt-4o
# Optional: override API base (default https://api.openai.com/v1)
# OPENAI_BASE_URL=https://api.openai.com/v1
